<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Free Social Media Audit | AW Media</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Rethink+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <header class="hero">
      <div class="badge">FREE AUDIT</div>
      <h1>We'll Scan Your <span class="accent">Real Profiles.</span><br>You'll See What's Broken.</h1>
      <p class="subtitle">Enter your social media handles. We'll scrape your actual profiles and score you across 5 dimensions with real data — not guesswork.</p>
      <p class="time-estimate">Takes about 60 seconds</p>
    </header>

    <form id="auditForm">
      <!-- Progress -->
      <div class="progress-container">
        <div class="progress-bar" id="progressBar"></div>
        <div class="progress-steps">
          <span class="step-dot active" data-step="1">1</span>
          <span class="step-dot" data-step="2">2</span>
        </div>
      </div>

      <!-- Step 1: Lead Capture -->
      <div class="form-step active" id="step1">
        <h2>Let's start with <span class="accent">you</span></h2>
        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" placeholder="e.g. Sarah Johnson" required>
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="e.g. sarah@yourbusiness.com" required>
          <span class="helper-text">We'll send your full audit report here</span>
        </div>
        <div class="form-group">
          <label for="business">What does your business do?</label>
          <textarea id="business" name="business" rows="2" placeholder="e.g. I'm a personal trainer helping busy professionals get fit with online coaching" required></textarea>
        </div>
        <div class="form-group">
          <label for="goal">What's your #1 goal with social media?</label>
          <select id="goal" name="goal" required>
            <option value="" disabled selected>Select your primary goal</option>
            <option value="brand_awareness">Brand Awareness — Get my name out there</option>
            <option value="lead_generation">Lead Generation — Book more calls & enquiries</option>
            <option value="direct_sales">Direct Sales — Drive purchases & revenue</option>
            <option value="community">Community Building — Build a loyal audience</option>
            <option value="thought_leadership">Thought Leadership — Become the go-to expert</option>
          </select>
        </div>
        <button type="button" class="btn btn-next" onclick="nextStep(1)">Next Step</button>
      </div>

      <!-- Step 2: Platform Handles -->
      <div class="form-step" id="step2">
        <h2>Enter your <span class="accent">social handles</span></h2>
        <p class="step-description">Add at least one. We'll scan each profile and analyse your real data.</p>

        <div class="handle-list">
          <div class="handle-group">
            <div class="handle-label">
              <span class="handle-icon">📸</span>
              <span>Instagram</span>
            </div>
            <input type="text" name="handle_instagram" placeholder="@yourusername">
          </div>

          <div class="handle-group">
            <div class="handle-label">
              <span class="handle-icon">🎵</span>
              <span>TikTok</span>
            </div>
            <input type="text" name="handle_tiktok" placeholder="@yourusername">
          </div>

          <div class="handle-group">
            <div class="handle-label">
              <span class="handle-icon">👥</span>
              <span>Facebook</span>
            </div>
            <input type="text" name="handle_facebook" placeholder="facebook.com/yourpage">
          </div>

          <div class="handle-group">
            <div class="handle-label">
              <span class="handle-icon">💼</span>
              <span>LinkedIn</span>
            </div>
            <input type="text" name="handle_linkedin" placeholder="linkedin.com/in/yourname">
          </div>

          <div class="handle-group">
            <div class="handle-label">
              <span class="handle-icon">▶️</span>
              <span>YouTube</span>
            </div>
            <input type="text" name="handle_youtube" placeholder="@channelname or channel URL">
          </div>

          <div class="handle-group">
            <div class="handle-label">
              <span class="handle-icon">𝕏</span>
              <span>X / Twitter</span>
            </div>
            <input type="text" name="handle_twitter" placeholder="@yourusername">
          </div>

          <div class="handle-group">
            <div class="handle-label">
              <span class="handle-icon">📌</span>
              <span>Pinterest</span>
            </div>
            <input type="text" name="handle_pinterest" placeholder="@yourusername or profile URL">
          </div>
        </div>

        <div id="formError" class="form-error" style="display:none;"></div>

        <div class="btn-row">
          <button type="button" class="btn btn-back" onclick="prevStep(2)">Back</button>
          <button type="button" class="btn btn-submit" id="submitBtn" onclick="submitAudit()">Analyse My Profiles</button>
        </div>
      </div>
    </form>
  </div>

  <script>
    let currentStep = 1;

    function nextStep(current) {
      const stepEl = document.getElementById(`step${current}`);
      const inputs = stepEl.querySelectorAll('input[required], select[required], textarea[required]');
      for (let input of inputs) {
        if (!input.value.trim()) {
          input.focus();
          input.classList.add('error');
          return;
        }
      }
      document.getElementById(`step${current}`).classList.remove('active');
      document.getElementById(`step${current + 1}`).classList.add('active');
      currentStep = current + 1;
      updateProgress();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function prevStep(current) {
      document.getElementById(`step${current}`).classList.remove('active');
      document.getElementById(`step${current - 1}`).classList.add('active');
      currentStep = current - 1;
      updateProgress();
    }

    function updateProgress() {
      const pct = ((currentStep - 1) / 1) * 100;
      document.getElementById('progressBar').style.width = pct + '%';
      document.querySelectorAll('.step-dot').forEach(dot => {
        dot.classList.toggle('active', parseInt(dot.dataset.step) <= currentStep);
      });
    }

    async function submitAudit() {
      const form = document.getElementById('auditForm');
      const formData = new FormData(form);
      const data = {};
      formData.forEach((val, key) => { data[key] = val; });

      // Check at least one handle
      const handles = Object.keys(data).filter(k => k.startsWith('handle_') && data[k].trim());
      if (handles.length === 0) {
        const errEl = document.getElementById('formError');
        errEl.textContent = 'Please enter at least one social media handle.';
        errEl.style.display = 'block';
        return;
      }

      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.textContent = 'Starting analysis...';

      try {
        const resp = await fetch('/api/audit/start', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const result = await resp.json();
        if (result.error) {
          throw new Error(result.error);
        }
        window.location.href = `/audit/loading?id=${result.auditId}`;
      } catch (err) {
        btn.disabled = false;
        btn.textContent = 'Analyse My Profiles';
        const errEl = document.getElementById('formError');
        errEl.textContent = err.message || 'Something went wrong. Please try again.';
        errEl.style.display = 'block';
      }
    }

    document.addEventListener('input', (e) => {
      e.target.classList.remove('error');
      document.getElementById('formError').style.display = 'none';
    });
  </script>
</body>
</html>
