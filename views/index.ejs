<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Free Social Media Audit | Always On Time</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Rethink+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <!-- Hero Section -->
    <header class="hero">
      <div class="badge">FREE AUDIT</div>
      <h1>Your Social Media<br><span class="accent">Isn't Working.</span><br>Let's Find Out Why.</h1>
      <p class="subtitle">Answer 7 quick questions. Get an instant scorecard showing exactly where you're losing followers, engagement, and revenue.</p>
      <p class="time-estimate">Takes less than 3 minutes</p>
    </header>

    <!-- Multi-step Form -->
    <form id="auditForm" action="/audit" method="POST">
      <!-- Progress Bar -->
      <div class="progress-container">
        <div class="progress-bar" id="progressBar"></div>
        <div class="progress-steps">
          <span class="step-dot active" data-step="1">1</span>
          <span class="step-dot" data-step="2">2</span>
          <span class="step-dot" data-step="3">3</span>
          <span class="step-dot" data-step="4">4</span>
          <span class="step-dot" data-step="5">5</span>
        </div>
      </div>

      <!-- Step 1: Lead Capture + Business Info -->
      <div class="form-step active" id="step1">
        <h2>Let's start with <span class="accent">you</span></h2>
        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" placeholder="e.g. Sarah Johnson" required>
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="e.g. sarah@yourbusiness.com" required>
          <span class="helper-text">We'll send your full audit report here</span>
        </div>
        <div class="form-group">
          <label for="business">What does your business do?</label>
          <textarea id="business" name="business" rows="2" placeholder="e.g. I'm a personal trainer helping busy professionals get fit with online coaching" required></textarea>
        </div>
        <div class="form-group">
          <label for="goal">What's your #1 goal with social media?</label>
          <select id="goal" name="goal" required>
            <option value="" disabled selected>Select your primary goal</option>
            <option value="brand_awareness">Brand Awareness — Get my name out there</option>
            <option value="lead_generation">Lead Generation — Book more calls & enquiries</option>
            <option value="direct_sales">Direct Sales — Drive purchases & revenue</option>
            <option value="community">Community Building — Build a loyal audience</option>
            <option value="thought_leadership">Thought Leadership — Become the go-to expert</option>
          </select>
        </div>
        <button type="button" class="btn btn-next" onclick="nextStep(1)">Next Step →</button>
      </div>

      <!-- Step 2: Platform Selection -->
      <div class="form-step" id="step2">
        <h2>Which platforms are you <span class="accent">active</span> on?</h2>
        <p class="step-description">Select all platforms where you have an account and have posted at least once.</p>
        <div class="platform-grid">
          <label class="platform-card">
            <input type="checkbox" name="platforms" value="instagram">
            <div class="platform-inner">
              <div class="platform-icon">📸</div>
              <span>Instagram</span>
            </div>
          </label>
          <label class="platform-card">
            <input type="checkbox" name="platforms" value="tiktok">
            <div class="platform-inner">
              <div class="platform-icon">🎵</div>
              <span>TikTok</span>
            </div>
          </label>
          <label class="platform-card">
            <input type="checkbox" name="platforms" value="linkedin">
            <div class="platform-inner">
              <div class="platform-icon">💼</div>
              <span>LinkedIn</span>
            </div>
          </label>
          <label class="platform-card">
            <input type="checkbox" name="platforms" value="facebook">
            <div class="platform-inner">
              <div class="platform-icon">👥</div>
              <span>Facebook</span>
            </div>
          </label>
          <label class="platform-card">
            <input type="checkbox" name="platforms" value="twitter">
            <div class="platform-inner">
              <div class="platform-icon">𝕏</div>
              <span>X / Twitter</span>
            </div>
          </label>
          <label class="platform-card">
            <input type="checkbox" name="platforms" value="youtube">
            <div class="platform-inner">
              <div class="platform-icon">▶️</div>
              <span>YouTube</span>
            </div>
          </label>
          <label class="platform-card">
            <input type="checkbox" name="platforms" value="pinterest">
            <div class="platform-inner">
              <div class="platform-icon">📌</div>
              <span>Pinterest</span>
            </div>
          </label>
        </div>
        <div class="btn-row">
          <button type="button" class="btn btn-back" onclick="prevStep(2)">← Back</button>
          <button type="button" class="btn btn-next" onclick="nextStep(2)">Next Step →</button>
        </div>
      </div>

      <!-- Step 3: Profile & Content (per platform) -->
      <div class="form-step" id="step3">
        <h2>Tell us about your <span class="accent">profile & content</span></h2>
        <p class="step-description">Answer for each of your active platforms.</p>
        <div id="platformQuestions3"></div>
        <div class="btn-row">
          <button type="button" class="btn btn-back" onclick="prevStep(3)">← Back</button>
          <button type="button" class="btn btn-next" onclick="nextStep(3)">Next Step →</button>
        </div>
      </div>

      <!-- Step 4: Consistency & Engagement (per platform) -->
      <div class="form-step" id="step4">
        <h2>How's your <span class="accent">consistency & engagement</span>?</h2>
        <p class="step-description">Be honest — this is how we find the real opportunities.</p>
        <div id="platformQuestions4"></div>
        <div class="btn-row">
          <button type="button" class="btn btn-back" onclick="prevStep(4)">← Back</button>
          <button type="button" class="btn btn-next" onclick="nextStep(4)">Next Step →</button>
        </div>
      </div>

      <!-- Step 5: Growth & Strategy (per platform) -->
      <div class="form-step" id="step5">
        <h2>Let's talk <span class="accent">growth</span></h2>
        <div id="platformQuestions5"></div>
        <div class="btn-row">
          <button type="button" class="btn btn-back" onclick="prevStep(5)">← Back</button>
          <button type="submit" class="btn btn-submit">Get My Free Audit →</button>
        </div>
      </div>
    </form>
  </div>

  <script>
    let currentStep = 1;
    const totalSteps = 5;

    function getSelectedPlatforms() {
      return Array.from(document.querySelectorAll('input[name="platforms"]:checked')).map(cb => cb.value);
    }

    function capitalize(str) {
      if (str === 'twitter') return 'X / Twitter';
      if (str === 'tiktok') return 'TikTok';
      if (str === 'youtube') return 'YouTube';
      if (str === 'linkedin') return 'LinkedIn';
      if (str === 'pinterest') return 'Pinterest';
      return str.charAt(0).toUpperCase() + str.slice(1);
    }

    function generatePlatformQuestions3(platforms) {
      const container = document.getElementById('platformQuestions3');
      container.innerHTML = '';
      platforms.forEach(platform => {
        const pName = capitalize(platform);
        container.innerHTML += `
          <div class="platform-section">
            <h3 class="platform-section-title">${pName}</h3>
            <div class="form-group">
              <label>How clear is your bio/about section?</label>
              <select name="bio_clarity_${platform}" required>
                <option value="3">Clear — says what I do and who I help</option>
                <option value="2">Exists but vague or generic</option>
                <option value="1">Empty or irrelevant</option>
              </select>
            </div>
            <div class="form-group">
              <label>Do you have a working link in your profile?</label>
              <div class="radio-row">
                <label class="radio-label"><input type="radio" name="has_link_${platform}" value="yes" required> Yes</label>
                <label class="radio-label"><input type="radio" name="has_link_${platform}" value="no"> No</label>
              </div>
            </div>
            <div class="form-group">
              <label>Profile photo quality?</label>
              <select name="photo_quality_${platform}" required>
                <option value="3">Professional headshot or quality logo</option>
                <option value="2">Exists but low quality or inconsistent</option>
                <option value="1">Default avatar or missing</option>
              </select>
            </div>
            <div class="form-group">
              <label>Do you have pinned posts or highlights?</label>
              <div class="radio-row">
                <label class="radio-label"><input type="radio" name="pinned_content_${platform}" value="yes" required> Yes</label>
                <label class="radio-label"><input type="radio" name="pinned_content_${platform}" value="no"> No</label>
              </div>
            </div>
            <div class="form-group">
              <label>Visual consistency across your posts?</label>
              <select name="visual_consistency_${platform}" required>
                <option value="3">Consistent brand look — recognizable at a glance</option>
                <option value="2">Somewhat consistent but no clear brand style</option>
                <option value="1">Random visuals, no cohesion</option>
              </select>
            </div>
            <div class="form-group">
              <label>Caption / copy quality?</label>
              <select name="caption_quality_${platform}" required>
                <option value="3">Strong hooks, clear message, calls to action</option>
                <option value="2">Captions exist but flat or unfocused</option>
                <option value="1">No captions, single emojis, or copy-paste</option>
              </select>
            </div>
            <div class="form-group">
              <label>Content mix — value vs. promotional?</label>
              <select name="content_mix_${platform}" required>
                <option value="3">Mostly value-driven (educate/entertain), some promo</option>
                <option value="2">Some value but too much selling or filler</option>
                <option value="1">All promotional or completely random</option>
              </select>
            </div>
          </div>
        `;
      });
    }

    function generatePlatformQuestions4(platforms) {
      const container = document.getElementById('platformQuestions4');
      container.innerHTML = '';
      platforms.forEach(platform => {
        const pName = capitalize(platform);
        container.innerHTML += `
          <div class="platform-section">
            <h3 class="platform-section-title">${pName}</h3>
            <div class="form-group">
              <label>How many times per week do you post?</label>
              <select name="frequency_${platform}" required>
                <option value="7">Daily (7+/week)</option>
                <option value="5">Most days (5-6/week)</option>
                <option value="3">A few times (3-4/week)</option>
                <option value="1">Once a week or less</option>
                <option value="0">Rarely / almost never</option>
              </select>
            </div>
            <div class="form-group">
              <label>Do you have gaps of 2+ weeks with no posts?</label>
              <div class="radio-row">
                <label class="radio-label"><input type="radio" name="has_gaps_${platform}" value="yes" required> Yes, it happens</label>
                <label class="radio-label"><input type="radio" name="has_gaps_${platform}" value="no"> No, I stay consistent</label>
              </div>
            </div>
            <div class="form-group">
              <label>Do you use a scheduling tool?</label>
              <div class="radio-row">
                <label class="radio-label"><input type="radio" name="uses_scheduler_${platform}" value="yes" required> Yes</label>
                <label class="radio-label"><input type="radio" name="uses_scheduler_${platform}" value="no"> No, I post manually</label>
              </div>
            </div>
            <div class="form-group">
              <label>How quickly do you reply to comments?</label>
              <select name="replies_speed_${platform}" required>
                <option value="3">Within a few hours</option>
                <option value="2">Within a day or two</option>
                <option value="1">Rarely or never reply</option>
              </select>
            </div>
            <div class="form-group">
              <label>Do you engage with other accounts in your niche?</label>
              <select name="outbound_engagement_${platform}" required>
                <option value="3">Yes, regularly — I comment on others' posts</option>
                <option value="2">Occasionally</option>
                <option value="1">No — I just post my own content</option>
              </select>
            </div>
            <div class="form-group">
              <label>Do your posts include clear calls to action?</label>
              <div class="radio-row">
                <label class="radio-label"><input type="radio" name="uses_ctas_${platform}" value="yes" required> Yes</label>
                <label class="radio-label"><input type="radio" name="uses_ctas_${platform}" value="no"> Not really</label>
              </div>
            </div>
          </div>
        `;
      });
    }

    function generatePlatformQuestions5(platforms) {
      const container = document.getElementById('platformQuestions5');
      container.innerHTML = '';
      platforms.forEach(platform => {
        const pName = capitalize(platform);
        container.innerHTML += `
          <div class="platform-section">
            <h3 class="platform-section-title">${pName}</h3>
            <div class="form-group">
              <label>How are your followers trending?</label>
              <select name="follower_trend_${platform}" required>
                <option value="3">Growing steadily</option>
                <option value="2">Flat — not much change</option>
                <option value="1">Declining or stagnant for months</option>
              </select>
            </div>
            <div class="form-group">
              <label>Do you know which content types perform best?</label>
              <div class="radio-row">
                <label class="radio-label"><input type="radio" name="knows_top_content_${platform}" value="yes" required> Yes, I replicate what works</label>
                <label class="radio-label"><input type="radio" name="knows_top_content_${platform}" value="no"> No idea</label>
              </div>
            </div>
            <div class="form-group">
              <label>Do you use a hashtag or keyword strategy?</label>
              <div class="radio-row">
                <label class="radio-label"><input type="radio" name="uses_hashtags_${platform}" value="yes" required> Yes</label>
                <label class="radio-label"><input type="radio" name="uses_hashtags_${platform}" value="no"> No</label>
              </div>
            </div>
            <div class="form-group">
              <label>Do you cross-promote between platforms?</label>
              <div class="radio-row">
                <label class="radio-label"><input type="radio" name="cross_promotes_${platform}" value="yes" required> Yes</label>
                <label class="radio-label"><input type="radio" name="cross_promotes_${platform}" value="no"> No, each platform is separate</label>
              </div>
            </div>
          </div>
        `;
      });
    }

    function nextStep(current) {
      // Validation
      const stepEl = document.getElementById(`step${current}`);
      const inputs = stepEl.querySelectorAll('input[required], select[required], textarea[required]');
      let valid = true;

      if (current === 2) {
        const platforms = getSelectedPlatforms();
        if (platforms.length === 0) {
          alert('Please select at least one platform.');
          return;
        }
        // Generate dynamic questions for selected platforms
        generatePlatformQuestions3(platforms);
        generatePlatformQuestions4(platforms);
        generatePlatformQuestions5(platforms);
      }

      // Check required fields for non-dynamic steps
      if (current !== 2) {
        for (let input of inputs) {
          if (!input.value) {
            input.focus();
            input.classList.add('error');
            valid = false;
            break;
          }
        }
        if (!valid) return;
      }

      // Check radio groups in current step
      if (current >= 3) {
        const radioGroups = new Set();
        stepEl.querySelectorAll('input[type="radio"][required]').forEach(r => radioGroups.add(r.name));
        for (let groupName of radioGroups) {
          if (!document.querySelector(`input[name="${groupName}"]:checked`)) {
            alert('Please answer all questions before continuing.');
            return;
          }
        }
      }

      document.getElementById(`step${current}`).classList.remove('active');
      document.getElementById(`step${current + 1}`).classList.add('active');
      currentStep = current + 1;
      updateProgress();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function prevStep(current) {
      document.getElementById(`step${current}`).classList.remove('active');
      document.getElementById(`step${current - 1}`).classList.add('active');
      currentStep = current - 1;
      updateProgress();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function updateProgress() {
      const pct = ((currentStep - 1) / (totalSteps - 1)) * 100;
      document.getElementById('progressBar').style.width = pct + '%';
      document.querySelectorAll('.step-dot').forEach(dot => {
        const step = parseInt(dot.dataset.step);
        dot.classList.toggle('active', step <= currentStep);
      });
    }

    // Remove error class on input
    document.addEventListener('input', (e) => {
      e.target.classList.remove('error');
    });
  </script>
</body>
</html>
