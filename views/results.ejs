<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Social Media Audit Results | Always On Time</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Rethink+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container results-page">

    <!-- Score Hero -->
    <header class="results-hero">
      <p class="results-greeting">Hey <span class="accent"><%= data.name.split(' ')[0] %></span>, here's your audit.</p>
      <div class="score-ring-container">
        <div class="score-ring">
          <svg viewBox="0 0 200 200">
            <circle class="score-ring-bg" cx="100" cy="100" r="85" />
            <circle class="score-ring-fill" cx="100" cy="100" r="85"
              stroke-dasharray="534"
              stroke-dashoffset="<%= 534 - (534 * results.overallScore / 100) %>" />
          </svg>
          <div class="score-ring-text">
            <span class="score-number"><%= results.overallScore %></span>
            <span class="score-label">/ 100</span>
          </div>
        </div>
        <div class="grade-badge grade-<%= results.grade.toLowerCase() %>"><%= results.grade %></div>
      </div>
      <p class="score-summary">
        <% if (results.overallScore >= 70) { %>
          Solid foundation — but there's still revenue being left on the table.
        <% } else if (results.overallScore >= 45) { %>
          Your social media is underperforming. The good news? The fixes are clear.
        <% } else { %>
          Your social media presence needs serious attention. Every day without fixing this is costing you.
        <% } %>
      </p>
    </header>

    <!-- Platform Scorecard -->
    <section class="section">
      <h2>Platform <span class="accent">Scorecard</span></h2>
      <div class="scorecard-table-wrapper">
        <table class="scorecard-table">
          <thead>
            <tr>
              <th>Dimension</th>
              <% Object.keys(results.platforms).forEach(platform => { %>
                <th><%= platform.charAt(0).toUpperCase() + platform.slice(1) %></th>
              <% }); %>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Profile Optimization</td>
              <% Object.values(results.platforms).forEach(s => { %>
                <td><span class="rating-pill rating-<%= s.profileOptimization.rating.toLowerCase().replace(' ', '-') %>"><%= s.profileOptimization.rating %></span></td>
              <% }); %>
            </tr>
            <tr>
              <td>Content Quality</td>
              <% Object.values(results.platforms).forEach(s => { %>
                <td><span class="rating-pill rating-<%= s.contentQuality.rating.toLowerCase().replace(' ', '-') %>"><%= s.contentQuality.rating %></span></td>
              <% }); %>
            </tr>
            <tr>
              <td>Posting Consistency</td>
              <% Object.values(results.platforms).forEach(s => { %>
                <td><span class="rating-pill rating-<%= s.postingConsistency.rating.toLowerCase().replace(' ', '-') %>"><%= s.postingConsistency.rating %></span></td>
              <% }); %>
            </tr>
            <tr>
              <td>Engagement Health</td>
              <% Object.values(results.platforms).forEach(s => { %>
                <td><span class="rating-pill rating-<%= s.engagementHealth.rating.toLowerCase().replace(' ', '-') %>"><%= s.engagementHealth.rating %></span></td>
              <% }); %>
            </tr>
            <tr>
              <td>Growth Signals</td>
              <% Object.values(results.platforms).forEach(s => { %>
                <td><span class="rating-pill rating-<%= s.growthSignals.rating.toLowerCase().replace(' ', '-') %>"><%= s.growthSignals.rating %></span></td>
              <% }); %>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- What's Working -->
    <% if (results.insights.wins.length > 0) { %>
    <section class="section">
      <h2>What's <span class="accent">Working</span></h2>
      <div class="insight-cards">
        <% results.insights.wins.forEach((win, i) => { %>
          <div class="insight-card win-card">
            <div class="insight-icon">✓</div>
            <div class="insight-content">
              <span class="insight-platform"><%= win.platform %></span>
              <p><%= win.text %></p>
            </div>
          </div>
        <% }); %>
      </div>
    </section>
    <% } %>

    <!-- Biggest Gaps -->
    <section class="section">
      <h2>Biggest <span class="accent">Gaps</span></h2>
      <div class="insight-cards">
        <% results.insights.gaps.forEach((gap, i) => { %>
          <div class="insight-card gap-card">
            <div class="insight-icon">!</div>
            <div class="insight-content">
              <span class="insight-platform"><%= gap.platform %></span>
              <p><%= gap.text %></p>
            </div>
          </div>
        <% }); %>
      </div>
      <% if (results.insights.totalGaps > 3) { %>
        <div class="locked-teaser">
          <p>+ <%= results.insights.totalGaps - 3 %> more gaps identified in your full audit</p>
        </div>
      <% } %>
    </section>

    <!-- Quick Wins (Teaser) -->
    <section class="section">
      <h2>Quick Wins <span class="accent">You Can Fix Today</span></h2>
      <div class="quick-wins">
        <% results.insights.quickWins.forEach((qw, i) => { %>
          <div class="quick-win-item">
            <div class="qw-number"><%= i + 1 %></div>
            <div class="qw-content">
              <span class="insight-platform"><%= qw.platform %></span>
              <p><%= qw.text %></p>
            </div>
          </div>
        <% }); %>
      </div>
      <% if (results.insights.totalQuickWins > 2) { %>
        <div class="locked-section">
          <div class="locked-items">
            <% for (let i = 0; i < Math.min(results.insights.totalQuickWins - 2, 3); i++) { %>
              <div class="locked-item">
                <div class="qw-number locked"><%= i + 3 %></div>
                <div class="locked-bar"></div>
              </div>
            <% } %>
          </div>
          <div class="locked-overlay">
            <div class="lock-icon">🔒</div>
            <p><%= results.insights.totalQuickWins - 2 %> more quick wins + your full 30-day action plan</p>
          </div>
        </div>
      <% } %>
    </section>

    <!-- 30-Day Plan Teaser -->
    <section class="section plan-teaser-section">
      <h2>Your 30-Day <span class="accent">Action Plan</span></h2>
      <div class="plan-teaser">
        <div class="plan-week visible">
          <h3>Week 1: Foundation Fixes</h3>
          <p>Quick profile optimizations and setup changes that create immediate impact...</p>
        </div>
        <div class="plan-week blurred">
          <h3>Week 2: Content System</h3>
          <p>Build a repeatable posting system with defined pillars and batching...</p>
        </div>
        <div class="plan-week blurred">
          <h3>Week 3: Engagement Engine</h3>
          <p>Daily routines and strategies to build real community interaction...</p>
        </div>
        <div class="plan-week blurred">
          <h3>Week 4: Growth & Measurement</h3>
          <p>Scale what works, cut what doesn't, and set up tracking for next month...</p>
        </div>
        <div class="plan-locked-overlay">
          <div class="lock-icon">🔒</div>
          <p>Unlock your personalized 30-day plan</p>
        </div>
      </div>
    </section>

    <!-- CTA: Upsell AW-LWAYS On Time -->
    <section class="section cta-section">
      <div class="cta-card">
        <div class="cta-badge">AW-LWAYS ON TIME</div>
        <h2>Stop Struggling With<br><span class="accent">Social Media Graphics</span></h2>
        <p class="cta-subtitle">Your audit flagged gaps in visual consistency, posting frequency, or both. That's not a strategy problem — it's a <strong>design bottleneck</strong>. Let AW Media handle the visuals so you can focus on running your business.</p>

        <div class="upsell-features">
          <div class="upsell-feature">
            <div class="feature-icon">🎨</div>
            <div>
              <h4>Custom Graphics, On Brand</h4>
              <p>Carousels, YouTube thumbnails, lead gen designs, single posts — all tailored to your brand and audience</p>
            </div>
          </div>
          <div class="upsell-feature">
            <div class="feature-icon">⏱️</div>
            <div>
              <h4>Delivered Like Clockwork</h4>
              <p>Weekly, fortnightly, or monthly — your dedicated design slot means content is always ready to post</p>
            </div>
          </div>
          <div class="upsell-feature">
            <div class="feature-icon">🔄</div>
            <div>
              <h4>Flexible When You're Busy</h4>
              <p>Can't submit content this week? Swap your graphics for a 10-page PDF lead magnet or website design updates instead</p>
            </div>
          </div>
          <div class="upsell-feature">
            <div class="feature-icon">⭐</div>
            <div>
              <h4>Award-Winning Team</h4>
              <p>Sheffield-based studio, founded 2016. 1,000+ happy clients. 500+ five-star reviews.</p>
            </div>
          </div>
        </div>

        <!-- Pricing Cards -->
        <div class="pricing-cards">
          <div class="pricing-card">
            <h4>Monthly</h4>
            <div class="price">£110<span>/mo</span></div>
            <p class="pricing-detail">3x graphics per month</p>
            <p class="pricing-saving">Save £30 per graphic</p>
          </div>
          <div class="pricing-card popular">
            <div class="popular-badge">MOST POPULAR</div>
            <h4>Fortnightly</h4>
            <div class="price">£190<span>/mo</span></div>
            <p class="pricing-detail">6x graphics per month<br>(3x every 2 weeks)</p>
            <p class="pricing-saving">Save £40 per graphic</p>
          </div>
          <div class="pricing-card">
            <h4>Weekly</h4>
            <div class="price">£300<span>/mo</span></div>
            <p class="pricing-detail">12x graphics per month<br>(3x every week)</p>
            <p class="pricing-saving">Save £50 per graphic</p>
          </div>
        </div>

        <div class="cta-proof">
          <p>No more stressing over design ideas, deadlines, or engagement — just consistent, scroll-stopping visuals that keep your brand looking sharp and performing strong.</p>
        </div>

        <div class="cta-buttons">
          <a href="https://awmedia.typeform.com/aw-lwaysontime" class="btn btn-cta" target="_blank">See Our Work →</a>
          <a href="mailto:alex@awmedia.marketing" class="btn btn-cta-secondary">Get In Touch</a>
        </div>
        <p class="cta-reassurance">3 month minimum term. Custom packages available. Pay-in-full discounts up to £300 off.</p>
      </div>
    </section>

    <!-- How It Works -->
    <section class="section">
      <h2>How It <span class="accent">Works</span></h2>
      <div class="steps-row">
        <div class="step-card">
          <div class="step-number">01</div>
          <h4>Research</h4>
          <p>We understand your brand, audience, and content goals to ensure every graphic hits the mark.</p>
        </div>
        <div class="step-card">
          <div class="step-number">02</div>
          <h4>Design</h4>
          <p>Our team creates bespoke, eye-catching visuals that reflect your style and maximise engagement.</p>
        </div>
        <div class="step-card">
          <div class="step-number">03</div>
          <h4>Delivery</h4>
          <p>Finished graphics are delivered on time, every time — ready for you to post with zero hassle.</p>
        </div>
      </div>
    </section>

    <!-- Footer CTA -->
    <section class="section footer-section">
      <div class="footer-recap">
        <h3>Your Score: <span class="accent"><%= results.overallScore %>/100</span></h3>
        <p>
          <% if (results.overallScore < 60) { %>
            Your social media is leaving money on the table. The quick wins alone could shift your results within a week — but the real transformation comes from having professional, on-brand graphics delivered like clockwork.
          <% } else { %>
            You've got a decent foundation — now it's about consistency and polish. Professional graphics on demand is the difference between "decent" and "can't stop scrolling."
          <% } %>
        </p>
        <a href="https://awmedia.typeform.com/aw-lwaysontime" class="btn btn-cta" target="_blank">Fix My Social Media →</a>
      </div>
    </section>

  </div>

  <script>
    // Animate score ring on load
    window.addEventListener('load', () => {
      const ring = document.querySelector('.score-ring-fill');
      if (ring) {
        const target = ring.getAttribute('stroke-dashoffset');
        ring.style.strokeDashoffset = '534';
        setTimeout(() => {
          ring.style.transition = 'stroke-dashoffset 1.5s ease-out';
          ring.style.strokeDashoffset = target;
        }, 300);
      }

      // Animate score number
      const scoreEl = document.querySelector('.score-number');
      if (scoreEl) {
        const target = parseInt(scoreEl.textContent);
        scoreEl.textContent = '0';
        let current = 0;
        const interval = setInterval(() => {
          current += 1;
          scoreEl.textContent = current;
          if (current >= target) clearInterval(interval);
        }, 20);
      }
    });
  </script>
</body>
</html>
